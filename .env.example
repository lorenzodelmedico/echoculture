# ============================================================
# SynkOS — environment template
# ============================================================
# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored — never commit it.
# ============================================================

# --- PostgreSQL (silver + gold layers, read by the UI) ---
POSTGRES_USER=synkos
POSTGRES_PASSWORD=change-me
POSTGRES_DB=synkos
# Hostname must be the docker service name (db_postgres) when running in compose.
POSTGRES_URL=postgresql://synkos:change-me@db_postgres:5432/synkos

# --- MongoDB (bronze layer: raw scrape archive + dedup hashes) ---
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change-me
MONGO_URL=mongodb://admin:change-me@db_mongodb:27017/

# --- Ollama (local LLM, used by the BDXC pipeline for event categorisation) ---
# Service name inside docker; do not change unless you rename the service.
OLLAMA_URL=http://ollama:11434/api/generate
LLM_MODEL=mistral

# --- Public URLs ---
# In local dev these can stay http://localhost:3000 / http://localhost:8000.
# In production set them to whatever public URL serves the front-/backend.
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
API_URL=http://localhost:8000

# --- Cloudflare Tunnel (optional, used only when running with --profile cloudflare) ---
# Get from https://one.dash.cloudflare.com → Networks → Tunnels.
# Leave empty if you expose the app via your own reverse proxy instead.
CLOUDFLARE_TUNNEL_TOKEN=

# --- Airflow ---
AIRFLOW_PUBLIC_URL=http://localhost:8080
# Random string. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=change-me

# --- Monitoring (optional) ---
# Discord incoming webhook for DAG failure alerts. Leave empty to disable.
URL_WEBHOOK_DIDI=

# --- Scraper tuning ---
# How many days ahead the price scraper looks when fetching event prices.
PRICE_SCRAPE_DAYS_AHEAD=60
